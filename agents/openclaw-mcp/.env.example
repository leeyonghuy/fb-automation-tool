# ID spreadsheet (đoạn giữa /d/ và /edit trong URL)
SPREADSHEET_ID=

# Tên sheet/tab. Tự tạo nếu chưa có.
SHEET_NAME=Crawled

# Topic mặc định nếu LLM không truyền
DEFAULT_TOPIC=

# Bỏ qua URL đã có trong sheet
DEDUPLICATE=true

# Đường dẫn FILE service-account JSON trên máy host (Windows hoặc WSL).
# Lưu ý: với Docker Desktop + WSL2 dùng path POSIX:
#   /mnt/d/Contenfactory/API/nha-may-content-208dc5165e29.json
SERVICE_ACCOUNT_FILE=/mnt/d/Contenfactory/API/nha-may-content-208dc5165e29.json
