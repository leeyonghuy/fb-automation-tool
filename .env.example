# ContenFactory — biến môi trường mẫu.
# Copy file này sang `.env` và điền giá trị thật. KHÔNG commit `.env`.

# ─── Google Sheets ────────────────────────────────────────────────
# ID của Google Spreadsheet (Channels + Videos)
SPREADSHEET_ID=

# Đường dẫn file service account JSON (mặc định: API/nha-may-content-*.json)
# GOOGLE_CREDENTIALS_FILE=D:\Contenfactory\API\nha-may-content-xxx.json

# ─── AI: Gemini ───────────────────────────────────────────────────
GEMINI_API_KEY=

# ─── AI: 9router (OpenAI-compatible local router) ────────────────
ROUTER_BASE=http://localhost:20128/v1
ROUTER_KEY=
ROUTER_MODEL=gemini/gemini-2.5-flash-preview

# ─── ffmpeg / ffprobe ─────────────────────────────────────────────
# Để trống dùng PATH; hoặc trỏ tuyệt đối:
# FFMPEG_CMD=D:\ffmpeg\bin\ffmpeg.exe
# FFPROBE_CMD=D:\ffmpeg\bin\ffprobe.exe

# ─── Output dirs ──────────────────────────────────────────────────
# BASE_VIDEO_DIR=D:\Videos
# EDITED_VIDEO_DIR=D:\Videos\Edited
# LOG_DIR=D:\Contenfactory\logs
# COOKIES_DIR=D:\Contenfactory\crawler\cookies

# ─── IX Browser (FB automation) ───────────────────────────────────
# IX_API_BASE=http://127.0.0.1:53200/api/v2

# ─── ADB (BoxPhone) ───────────────────────────────────────────────
# ADB_PATH=C:\platform-tools\adb.exe

# ─── Mã hoá password trong accounts.json (cryptography.fernet) ────
# Sinh key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ACCOUNT_ENCRYPTION_KEY=
